---
import "../../styles/global.css";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import HomeLabArchitectureImage from "../../assets/homelab/homelab-architecture.png";
import UptimeKumaSummaryImage from "../../assets/homelab/uptimekuma-summary.png";
import ProxmoxSummaryImage from "../../assets/homelab/proxmox-summary.png";
import PiHoleSummaryImage from "../../assets/homelab/pihole-summary.png";
const projectImages = [
  {
    src: HomeLabArchitectureImage,
    alt: "Proxmox cluster architecture map",
  },
  {
    src: UptimeKumaSummaryImage,
    alt: "Image of uptime kuma uptime list",
  },
  {
    src: ProxmoxSummaryImage,
    alt: "Image of Proxmox summary with utilization totals",
  },
  {
    src: PiHoleSummaryImage,
    alt: "Image of PiHole Summary page",
  },
];
const title = "Proxmox Homelab";
const techList = ["Proxmox", "Pihole"];
---

<ProjectLayout title={title} tech={techList} imageGallery={projectImages} />
